/* detail.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 逾期横幅 */
.overdue-banner {
  background: #FFF0F0;
  border: 1rpx solid #FF6B6B;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.overdue-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.overdue-banner text {
  color: #FF6B6B;
  font-size: 26rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-guzi { background: #FFF0F6; color: #FF6B9D; }
.tag-hanfu { background: #F6FFED; color: #52C41A; }
.tag-lo { background: #FFF7E6; color: #FF9500; }
.tag-other { background: #F5F5F5; color: #999; }

.detail-shop {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.detail-amounts {
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.amount-row:not(:last-child) {
  border-bottom: 1rpx solid #E0E0E0;
}

.amount-row.total {
  border-top: 2rpx solid #E0E0E0;
  margin-top: 12rpx;
  padding-top: 20rpx;
  font-weight: 600;
}

.amount-label {
  color: #666;
}

.amount {
  font-size: 30rpx;
  font-weight: 500;
}

.amount-paid {
  color: #07C160;
}

.amount-pending {
  color: #FF6B6B;
}

.amount-row.total .amount {
  font-size: 40rpx;
}

.detail-deadline {
  display: flex;
  align-items: flex-start;
  background: #FFF8E6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.deadline-label {
  color: #666;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.deadline-right {
  display: flex;
  flex-direction: column;
}

.deadline-date {
  font-size: 30rpx;
  font-weight: 500;
}

.deadline-date.urgent {
  color: #FF9500;
}

.deadline-date.overdue {
  color: #FF6B6B;
}

.deadline-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.overdue-text {
  color: #FF6B6B;
  font-weight: 500;
}

.detail-remark {
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 20rpx;
}

.remark-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.remark-content {
  font-size: 28rpx;
  color: #333;
}

.detail-images {
  margin-top: 24rpx;
}

.images-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  display: inline-block;
}

/* 快捷支付 */
.quick-pay-section {
  margin-bottom: 24rpx;
}

.quick-pay-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.pay-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.quick-pay-btn text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btns .btn {
  flex: 1;
}

.btn-secondary {
  background: #F0F0F0;
  color: #333;
}

.btn-edit {
  background: #07C160;
  color: #fff;
}

.btn-danger {
  background: #FFF0F0;
  color: #FF6B6B;
}

/* 分享 */
.share-section {
  margin-top: 24rpx;
}

.share-btn {
  background: #F0F0F0;
  color: #666;
  font-size: 28rpx;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
}

.share-btn::after {
  border: none;
}
