<!--monthly.wxml-->
<view class="container">
  <!-- 月份选择器 -->
  <view class="month-selector">
    <picker mode="selector" range="{{months}}" range-key="label" bindchange="onMonthChange" value="{{selectedIndex}}">
      <view class="month-picker">
        <text class="month-label">{{selectedMonth}}</text>
        <text class="arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 统计概览卡片 -->
  <view class="overview-section" wx:if="{{monthData}}">
    <view class="overview-card">
      <view class="overview-header">
        <text class="overview-icon">💳</text>
        <text class="overview-title">待支付</text>
      </view>
      <text class="overview-amount highlight">¥{{monthData.unpaidTail}}</text>
      <text class="overview-desc">{{monthData.unpaidRecords}} 笔待付</text>
    </view>
    
    <view class="overview-card">
      <view class="overview-header">
        <text class="overview-icon">✅</text>
        <text class="overview-title">已消费</text>
      </view>
      <text class="overview-amount success">¥{{monthData.paidTail}}</text>
      <text class="overview-desc">{{monthData.paidRecords}} 笔已完成</text>
    </view>
  </view>

  <!-- 消费明细 -->
  <view class="section" wx:if="{{monthData && monthData.totalRecords > 0}}">
    <view class="section-header">
      <text class="section-title">消费明细</text>
    </view>
    
    <view class="stats-list">
      <view class="stat-row">
        <text class="stat-label">尾款总额</text>
        <text class="stat-value">¥{{monthData.totalTail}}</text>
      </view>
      <view class="stat-row">
        <text class="stat-label">定金总额</text>
        <text class="stat-value">¥{{monthData.depositTotal}}</text>
      </view>
      <view class="stat-row total">
        <text class="stat-label">累计消费</text>
        <text class="stat-value">¥{{monthData.totalTail + monthData.depositTotal}}</text>
      </view>
    </view>
  </view>

  <!-- 分类统计 -->
  <view class="section" wx:if="{{monthData && categoryStats.length > 0}}">
    <view class="section-header">
      <text class="section-title">分类分布</text>
    </view>
    
    <view class="category-list">
      <view class="category-item" wx:for="{{categoryStats}}" wx:key="category">
        <view class="category-icon" style="background: {{item.color}}20; color: {{item.color}}">{{item.icon}}</view>
        <view class="category-info">
          <text class="category-name">{{item.name}}</text>
          <text class="category-count">{{item.count}} 笔</text>
        </view>
        <view class="category-amount">
          <text>¥{{item.amount}}</text>
          <text class="category-percent">{{item.percent}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 待付日程 -->
  <view class="section" wx:if="{{monthData && upcomingList.length > 0}}">
    <view class="section-header">
      <text class="section-title">待付日程</text>
      <text class="section-more">未来 {{upcomingDays}} 天</text>
    </view>
    
    <view class="upcoming-list">
      <view class="upcoming-item" wx:for="{{upcomingList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="upcoming-info">
          <text class="upcoming-name">{{item.name}}</text>
          <text class="upcoming-date">{{item.daysLeftText}}</text>
        </view>
        <view class="upcoming-right">
          <text class="upcoming-amount">¥{{item.tailPrice}}</text>
          <view class="pay-btn" catchtap="markAsPaid" data-id="{{item.id}}">付款</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!monthData || monthData.totalRecords === 0}}">
    <view class="empty-icon">📦</view>
    <text class="empty-text">该月暂无尾款记录</text>
  </view>
</view>
