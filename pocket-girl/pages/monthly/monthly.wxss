/* monthly.wxss - Apple Style */
.container {
  min-height: 100vh;
  background: #F2F2F7;
  padding: 16rpx;
}

/* 月份选择器 */
.month-selector {
  margin-bottom: 20rpx;
}

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
}

.arrow {
  margin-left: 12rpx;
  color: #8E8E93;
  font-size: 28rpx;
}

/* 概览卡片 */
.overview-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.overview-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.overview-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.overview-title {
  font-size: 26rpx;
  color: #8E8E93;
}

.overview-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #000;
  display: block;
}

.overview-amount.highlight {
  color: #FF3B30;
}

.overview-amount.success {
  color: #34C759;
}

.overview-desc {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

/* 通用区块 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx 16rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

.section-more {
  font-size: 24rpx;
  color: #8E8E93;
}

/* 消费明细 */
.stats-list {
  padding: 0 20rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5EA;
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-row.total {
  border-top: 1rpx solid #E5E5EA;
  margin-top: 12rpx;
  padding-top: 24rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #3C3C43;
}

.stat-row.total .stat-label {
  font-weight: 600;
}

.stat-value {
  font-size: 28rpx;
  color: #3C3C43;
}

.stat-row.total .stat-value {
  font-weight: 600;
  font-size: 32rpx;
}

/* 分类列表 */
.category-list {
  padding: 8rpx 0;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 28rpx;
  color: #3C3C43;
  display: block;
}

.category-count {
  font-size: 24rpx;
  color: #8E8E93;
}

.category-amount {
  text-align: right;
}

.category-amount text {
  display: block;
  font-size: 28rpx;
  color: #3C3C43;
}

.category-percent {
  font-size: 22rpx;
  color: #8E8E93;
}

/* 待付日程 */
.upcoming-list {
  padding: 0 20rpx;
}

.upcoming-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5EA;
}

.upcoming-item:last-child {
  border-bottom: none;
}

.upcoming-info {
  flex: 1;
}

.upcoming-name {
  font-size: 28rpx;
  color: #3C3C43;
  display: block;
  margin-bottom: 4rpx;
}

.upcoming-date {
  font-size: 24rpx;
  color: #8E8E93;
}

.upcoming-right {
  display: flex;
  align-items: center;
}

.upcoming-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF3B30;
  margin-right: 16rpx;
}

.pay-btn {
  font-size: 24rpx;
  color: #007AFF;
  background: #007AFF20;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8E8E93;
}
