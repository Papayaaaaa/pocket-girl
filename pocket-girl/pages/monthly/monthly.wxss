/* monthly.wxss */
.container {
  padding: 32rpx;
}

.month-selector {
  margin-bottom: 32rpx;
}

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}

.stats-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.overview-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx;
  border-radius: 16rpx;
  color: #fff;
}

.overview-card:last-child {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.overview-label {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
}

.overview-value.success {
  color: #fff;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stat-value.highlight {
  color: #FF6B6B;
}

.stat-value.success {
  color: #07C160;
}

.category-stats {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  padding: 20rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

.category-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #E0E0E0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
}

.category-amount {
  font-size: 26rpx;
  color: #666;
  min-width: 100rpx;
  text-align: right;
}

.daily-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.daily-item {
  display: flex;
  gap: 24rpx;
}

.daily-date {
  font-size: 24rpx;
  color: #999;
  min-width: 120rpx;
  padding-top: 16rpx;
}

.daily-records {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF6B6B;
}

.record-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.record-name {
  font-size: 28rpx;
  color: #333;
}

.record-category {
  font-size: 24rpx;
}

.record-amount {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.mark-paid {
  width: 48rpx;
  height: 48rpx;
  background: #07C160;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}
