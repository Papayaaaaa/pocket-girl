<!--stats.wxml-->
<view class="container">
  <!-- 年份选择 -->
  <view class="year-selector">
    <picker mode="selector" range="{{years}}" bindchange="onYearChange" value="{{years.indexOf(selectedYear)}}">
      <view class="year-picker">
        <text>{{selectedYear}} 年</text>
        <text class="arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 周期切换 -->
  <view class="period-tabs">
    <view class="tab-item {{currentPeriod === 'month' ? 'active' : ''}}" bindtap="switchPeriod" data-period="month">月度</view>
    <view class="tab-item {{currentPeriod === 'half' ? 'active' : ''}}" bindtap="switchPeriod" data-period="half">半年</view>
    <view class="tab-item {{currentPeriod === 'year' ? 'active' : ''}}" bindtap="switchPeriod" data-period="year">年度</view>
  </view>

  <!-- 消费概览 -->
  <view class="overview-section">
    <view class="overview-card paid-card">
      <view class="overview-header">
        <text class="overview-icon">✅</text>
        <text class="overview-label">已支付（含定金）</text>
      </view>
      <text class="overview-amount paid">¥{{overview.totalPaid}}</text>
      <text class="overview-desc">其中定金 ¥{{overview.depositPaid}}，{{overview.paidCount}} 笔</text>
    </view>
    
    <view class="overview-card pending-card">
      <view class="overview-header">
        <text class="overview-icon">📅</text>
        <text class="overview-label">待支付（尾款）</text>
      </view>
      <text class="overview-amount pending">¥{{overview.totalPending}}</text>
      <text class="overview-desc">{{overview.pendingCount}} 笔预计</text>
    </view>
  </view>

  <!-- 月度趋势 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">月度趋势</text>
    </view>
    <view class="monthly-chart">
      <view class="chart-bars">
        <view class="chart-bar-item" wx:for="{{monthlyData}}" wx:key="month">
          <view class="bar-wrapper">
            <view class="bar-paid" style="height: {{item.paid / 100 * 100}}%"></view>
            <view class="bar-pending" style="height: {{item.pending / 100 * 100}}%"></view>
          </view>
          <text class="bar-label">{{item.month}}月</text>
        </view>
      </view>
      <view class="chart-legend">
        <view class="legend-item">
          <view class="legend-dot paid"></view>
          <text>已支付</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot pending"></view>
          <text>待支付</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分类统计 -->
  <view class="section" wx:if="{{categoryStats.length > 0}}">
    <view class="section-header">
      <text class="section-title">分类分布</text>
    </view>
    <view class="category-list">
      <view class="category-item" wx:for="{{categoryStats}}" wx:key="category">
        <view class="category-icon" style="background: {{item.color}}20; color: {{item.color}}">{{item.icon}}</view>
        <view class="category-info">
          <text class="category-name">{{item.name}}</text>
          <text class="category-count">{{item.count}} 笔</text>
        </view>
        <view class="category-amount">
          <text>¥{{item.amount}}</text>
          <text class="category-percent">{{item.percent}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 近期待付 -->
  <view class="section" wx:if="{{upcomingRecords.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期待付</text>
    </view>
    <view class="upcoming-list">
      <view class="upcoming-item" wx:for="{{upcomingRecords}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="upcoming-info">
          <text class="upcoming-name">{{item.name}}</text>
          <text class="upcoming-date">{{item.tailDeadline}}</text>
        </view>
        <text class="upcoming-amount">¥{{item.tailPrice}}</text>
      </view>
    </view>
  </view>
</view>
