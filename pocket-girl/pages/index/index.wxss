/* index.wxss - Apple Style */
.container {
  min-height: 100vh;
  background: #F2F2F7;
  padding: 0 16rpx;
  padding-bottom: 140rpx;
}

/* 顶部栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 4rpx 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #000;
}

.header-actions {
  display: flex;
  gap: 4rpx;
}

.action-icon {
  font-size: 36rpx;
  padding: 12rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  padding: 8rpx 16rpx;
  color: #8E8E93;
}

.search-cancel {
  font-size: 28rpx;
  color: #007AFF;
  margin-left: 16rpx;
}

/* 汇总栏 */
.summary-bar {
  display: flex;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,122,255,0.3);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.2);
}

.summary-item:last-child {
  border-right: none;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.summary-value.overdue {
  color: #FFE066;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.batch-info {
  font-size: 26rpx;
  color: #3C3C43;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  color: #007AFF;
}

.batch-btn.delete {
  background: #FF3B3020;
  color: #FF3B30;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #FFFFFF;
  padding: 8rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  gap: 8rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #8E8E93;
  border-radius: 10rpx;
}

.filter-item.active {
  background: #007AFF;
  color: #FFFFFF;
  font-weight: 500;
}

.filter-item.overdue-filter.active {
  background: #FF3B30;
}

.filter-count {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 记录卡片 */
.record-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.record-card.overdue {
  border-left: 6rpx solid #FF3B30;
}

.record-card.selectable {
  padding-left: 68rpx;
}

/* 批量选择框 */
.checkbox {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #C7C7CC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.checkbox-inner.checked {
  background: #007AFF;
  border-color: #007AFF;
  color: #FFFFFF;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3C3C43;
  flex: 1;
  margin-right: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.tag-guzi { background: #FF6B9D20; color: #FF6B9D; }
.tag-hanfu { background: #34C75920; color: #34C759; }
.tag-lo { background: #FF950020; color: #FF9500; }
.tag-other { background: #8E8E9320; color: #8E8E93; }

.record-shop {
  font-size: 24rpx;
  color: #8E8E93;
  margin-bottom: 16rpx;
}

.record-amounts {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #E5E5EA;
  border-bottom: 1rpx solid #E5E5EA;
  margin-bottom: 16rpx;
}

.amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.amount-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 4rpx;
}

.amount-item .amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #3C3C43;
}

.amount-paid {
  color: #34C759;
}

.amount-pending {
  color: #FF3B30;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.deadline {
  font-size: 24rpx;
  color: #8E8E93;
}

.deadline.urgent {
  color: #FF9500;
  font-weight: 500;
}

.deadline.overdue {
  color: #FF3B30;
  font-weight: 600;
}

.quick-pay-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  background: #007AFF;
  color: #FFFFFF;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  text-align: center;
  color: #8E8E93;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #FFFFFF;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -1rpx 3rpx rgba(0,0,0,0.1);
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bottom-icon-wrap {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.bottom-text {
  font-size: 20rpx;
  color: #8E8E93;
}

.add-btn {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,122,255,0.4);
  flex: none;
}

.add-icon {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: 300;
}
