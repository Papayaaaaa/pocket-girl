/* yearly.wxss */
.container {
  padding: 24rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 年份选择 */
.year-picker {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.year-btn {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.year-icon {
  font-size: 24rpx;
  color: #999;
}

.year-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 0 20rpx;
}

/* 年度汇总 */
.year-overview {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
}

.overview-amount {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}

.overview-detail {
  display: flex;
  justify-content: space-between;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 4rpx;
}

.detail-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.detail-value.paid {
  color: #A8E6CF;
}

.detail-value.pending {
  color: #FFE066;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

/* 月度趋势 */
.monthly-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.month-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.month-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.month-amount {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.month-count {
  font-size: 20rpx;
  color: #999;
}

/* 分类统计 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
}

.category-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.category-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.category-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.category-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.category-percent {
  font-size: 24rpx;
  color: #999;
}

.category-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.category-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
