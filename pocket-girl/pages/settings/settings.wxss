/* settings.wxss - Apple Style */
.container {
  padding: 16rpx;
  background: #F2F2F7;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 24rpx;
  color: #3C3C43;
  background: #F2F2F7;
  display: flex;
  align-items: center;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  color: #3C3C43;
  display: block;
  margin-bottom: 4rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.picker-value {
  font-size: 28rpx;
  color: #007AFF;
  background: #F2F2F7;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
}

/* 自定义提醒日期 */
.remind-days-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.remind-day-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background: #F2F2F7;
  color: #3C3C43;
  transition: all 0.2s;
}

.remind-day-item.active {
  background: #007AFF;
  color: #FFFFFF;
}

.remind-days-tip {
  font-size: 24rpx;
  color: #007AFF;
  margin-top: 16rpx;
}

.bind-tip {
  font-size: 24rpx;
  color: #8E8E93;
  margin-bottom: 16rpx;
  line-height: 1.6;
  background: #F2F2F7;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
}

.bind-success {
  color: #34C759;
}

.btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
  transition: all 0.3s ease;
  margin-bottom: 16rpx;
  border: none;
}

.btn:last-child {
  margin-bottom: 0;
}

.bind-btn {
  background: #007AFF;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
}

.test-btn {
  background: #F2F2F7;
  color: #007AFF;
}

.test-btn[disabled] {
  color: #C7C7CC;
  background: #F2F2F7;
}

/* 数据管理 */
.data-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.data-btn {
  flex: 1;
  background: #F2F2F7;
  color: #007AFF;
}

.danger-zone {
  border-top: 16rpx solid #F2F2F7;
  padding-top: 16rpx;
}

.danger-btn {
  background: #FFF2F0;
  color: #FF3B30;
}

/* 关于 */
.about {
  text-align: center;
}

.about-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #8E8E93;
  font-size: 26rpx;
}

.about-desc {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 通用 */
.setting-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.api-input {
  width: 100%;
  background: #F2F2F7;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
  border: 1rpx solid #E5E5EA;
}

.api-input:focus {
  border-color: #007AFF;
}
