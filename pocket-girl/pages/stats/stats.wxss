/* stats.wxss - Apple Style */
.container {
  min-height: 100vh;
  background: #F2F2F7;
  padding: 16rpx;
  padding-bottom: 120rpx;
}

/* 年份选择 */
.year-selector {
  margin-bottom: 16rpx;
}

.year-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.year-picker text {
  font-size: 32rpx;
  font-weight: 600;
  color: #3C3C43;
}

.year-picker .arrow {
  margin-left: 12rpx;
  color: #8E8E93;
}

/* 周期切换 */
.period-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8E8E93;
  border-radius: 10rpx;
}

.tab-item.active {
  background: #007AFF;
  color: #FFFFFF;
  font-weight: 500;
}

/* 概览卡片 */
.overview-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.overview-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.overview-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #8E8E93;
}

.overview-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #3C3C43;
  display: block;
}

.overview-amount.paid {
  color: #34C759;
}

.overview-amount.pending {
  color: #FF9500;
}

.overview-desc {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

/* 通用区块 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3C3C43;
}

/* 月度趋势图表 */
.monthly-chart {
  padding: 20rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding: 0 8rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 160rpx;
  width: 100%;
  justify-content: center;
}

.bar-paid {
  width: 20rpx;
  background: #34C759;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
}

.bar-pending {
  width: 20rpx;
  background: #FF9500;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #8E8E93;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-dot.paid {
  background: #34C759;
}

.legend-dot.pending {
  background: #FF9500;
}

/* 分类列表 */
.category-list {
  padding: 8rpx 0;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 28rpx;
  color: #3C3C43;
  display: block;
}

.category-count {
  font-size: 22rpx;
  color: #8E8E93;
}

.category-amount {
  text-align: right;
}

.category-amount text {
  display: block;
  font-size: 28rpx;
  color: #3C3C43;
}

.category-percent {
  font-size: 22rpx;
  color: #8E8E93;
}

/* 近期待付 */
.upcoming-list {
  padding: 0 20rpx;
}

.upcoming-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5EA;
}

.upcoming-item:last-child {
  border-bottom: none;
}

.upcoming-info {
  flex: 1;
}

.upcoming-name {
  font-size: 28rpx;
  color: #3C3C43;
  display: block;
  margin-bottom: 4rpx;
}

.upcoming-date {
  font-size: 22rpx;
  color: #8E8E93;
  background: #F2F2F7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.upcoming-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF3B30;
}
