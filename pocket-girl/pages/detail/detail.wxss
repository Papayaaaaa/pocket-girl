/* detail.wxss - Apple Style */
.container {
  padding: 16rpx;
  padding-bottom: 200rpx;
  background: #F2F2F7;
  min-height: 100vh;
}

/* 逾期横幅 */
.overdue-banner {
  background: #FFF2F0;
  border: 1rpx solid #FFCCC7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.overdue-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.overdue-banner text {
  color: #FF3B30;
  font-size: 26rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  flex: 1;
  margin-right: 16rpx;
  color: #000;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.tag-guzi { background: #FF6B9D20; color: #FF6B9D; }
.tag-hanfu { background: #34C75920; color: #34C759; }
.tag-lo { background: #FF950020; color: #FF9500; }
.tag-other { background: #8E8E9320; color: #8E8E93; }

.detail-shop {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 24rpx;
}

.detail-amounts {
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.amount-row:not(:last-child) {
  border-bottom: 1rpx solid #E5E5EA;
}

.amount-row.total {
  border-top: 1rpx solid #E5E5EA;
  margin-top: 12rpx;
  padding-top: 16rpx;
  font-weight: 600;
}

.amount-label {
  color: #8E8E93;
}

.amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #3C3C43;
}

.amount-paid {
  color: #34C759;
}

.amount-pending {
  color: #FF3B30;
}

.amount-row.total .amount {
  font-size: 40rpx;
}

.detail-deadline {
  display: flex;
  align-items: flex-start;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.deadline-label {
  color: #8E8E93;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.deadline-right {
  display: flex;
  flex-direction: column;
}

.deadline-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #3C3C43;
}

.deadline-date.urgent {
  color: #FF9500;
}

.deadline-date.overdue {
  color: #FF3B30;
}

.deadline-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

.overdue-text {
  color: #FF3B30;
  font-weight: 600;
}

.detail-remark {
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 20rpx;
}

.remark-label {
  font-size: 24rpx;
  color: #8E8E93;
  display: block;
  margin-bottom: 8rpx;
}

.remark-content {
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.5;
}

.detail-images {
  margin-top: 16rpx;
}

.images-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  display: inline-block;
}

/* 快捷支付 */
.quick-pay-section {
  margin-bottom: 16rpx;
}

.quick-pay-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #34C759 0%, #30D158 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(52,199,89,0.3);
}

.pay-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.quick-pay-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-btns .btn {
  flex: 1;
}

.btn-secondary {
  background: #F2F2F7;
  color: #007AFF;
}

.btn-edit {
  background: #007AFF;
  color: #FFFFFF;
}

.btn-danger {
  background: #FFF2F0;
  color: #FF3B30;
}

/* 分享 */
.share-section {
  margin-top: 16rpx;
}

.share-btn {
  background: #F2F2F7;
  color: #007AFF;
  font-size: 28rpx;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
}

.share-btn::after {
  border: none;
}
