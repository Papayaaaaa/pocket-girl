/* settings.wxss */
.container {
  padding: 24rpx;
  background: #F8F9FA;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F7;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.picker-value {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  background: #F5F5F7;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

/* 自定义提醒日期 */
.remind-days-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.remind-day-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background: #F5F5F7;
  color: #666;
  transition: all 0.2s;
}

.remind-day-item.active {
  background: #07C160;
  color: #fff;
}

.remind-days-tip {
  font-size: 24rpx;
  color: #07C160;
  margin-top: 16rpx;
}

.bind-tip {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
  line-height: 1.6;
  background: #F8F9FA;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.bind-success {
  color: #52C41A;
}

.btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 14rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
  transition: all 0.3s ease;
  margin-bottom: 16rpx;
}

.btn:last-child {
  margin-bottom: 0;
}

.bind-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.test-btn {
  background: linear-gradient(135deg, #f5f5f7 0%, #e8e8e8 100%);
  color: #333;
}

.test-btn[disabled] {
  color: #AAA;
  background: #F5F5F7;
}

/* 数据管理 */
.data-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.data-btn {
  flex: 1;
  background: #F5F5F7;
  color: #333;
}

.danger-zone {
  border-top: 1rpx solid #FFEBEB;
  padding-top: 20rpx;
}

.danger-btn {
  background: #FFF0F0;
  color: #FF6B6B;
}

/* 关于 */
.about {
  text-align: center;
}

.about-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}

.about-desc {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 通用 */
.setting-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.api-input {
  width: 100%;
  background: #F8F9FA;
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 28rpx;
  margin-top: 14rpx;
  border: 2rpx solid #F0F0F0;
  transition: border-color 0.3s ease;
}

.api-input:focus {
  border-color: #667eea;
}
