/* stats.wxss - 现代扁平ins风 */

/* 周期切换 tabs */
.period-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 总览卡片 */
.stats-overview {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.overview-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 28rpx;
  font-weight: 500;
}

.overview-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.overview-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: -1rpx;
}

.overview-amount.pending {
  color: #FFE066;
}

.overview-amount.paid {
  color: #A8E6CF;
}

.overview-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.total-amount {
  font-size: 38rpx;
  font-weight: 700;
}

/* 分类统计 */
.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
}

.category-bars {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-bar-item {
  display: flex;
  flex-direction: column;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.bar-label text:last-child {
  font-weight: 600;
  color: #333;
}

.bar-track {
  height: 20rpx;
  background: #F5F5F7;
  border-radius: 10rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 近期到期 */
.upcoming-list {
  display: flex;
  flex-direction: column;
}

.upcoming-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.upcoming-item:last-child {
  border-bottom: none;
}

.upcoming-info {
  display: flex;
  flex-direction: column;
}

.upcoming-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.upcoming-date {
  font-size: 22rpx;
  color: #AAA;
  background: #F5F5F7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.upcoming-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B6B;
}
