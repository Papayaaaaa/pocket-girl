/* index.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 0 24rpx;
  padding-bottom: 140rpx;
}

/* 顶部栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 8rpx;
}

.action-icon {
  font-size: 36rpx;
  padding: 8rpx 12rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  padding: 8rpx 16rpx;
  color: #999;
}

.search-cancel {
  font-size: 28rpx;
  color: #07C160;
  margin-left: 16rpx;
}

/* 汇总栏 */
.summary-bar {
  display: flex;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.3);
}

.summary-item:last-child {
  border-right: none;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.summary-value.overdue {
  color: #FFE066;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.batch-info {
  font-size: 26rpx;
  color: #333;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #F0F0F0;
  color: #333;
}

.batch-btn.delete {
  background: #FF6B6B;
  color: #fff;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  gap: 8rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

.filter-item.overdue-filter.active {
  background: #FF6B6B;
}

.filter-count {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 记录列表 */
.record-list {
  /* padding-bottom: 120rpx; */
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.record-card.overdue {
  border-left: 6rpx solid #FF6B6B;
}

.record-card.selectable {
  padding-left: 64rpx;
}

/* 批量选择框 */
.checkbox {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.checkbox-inner.checked {
  background: #07C160;
  border-color: #07C160;
  color: #fff;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-guzi { background: #FFF0F6; color: #FF6B9D; }
.tag-hanfu { background: #F6FFED; color: #52C41A; }
.tag-lo { background: #FFF7E6; color: #FF9500; }
.tag-other { background: #F5F5F5; color: #999; }

.record-shop {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.record-amounts {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.amount-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.amount-item .amount {
  font-size: 28rpx;
  font-weight: 500;
}

.amount-paid {
  color: #07C160;
}

.amount-pending {
  color: #FF6B6B;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.deadline {
  font-size: 24rpx;
  color: #666;
}

.deadline.urgent {
  color: #FF6B6B;
  font-weight: 500;
}

.deadline.overdue {
  color: #FF6B6B;
  font-weight: 600;
}

.quick-pay-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  background: #07C160;
  color: #fff;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  text-align: center;
  color: #999;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bottom-icon {
  font-size: 36rpx;
}

.bottom-text {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.add-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  flex: none;
}

.add-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}
