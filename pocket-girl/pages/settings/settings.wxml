<!--settings.wxml-->
<view class="container">
  <!-- AI 识别设置 -->
  <view class="section">
    <view class="section-title">🤖 AI 智能识别设置</view>
    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-label">AI 提供商</text>
        <text class="setting-desc">选择要使用的 AI 服务</text>
      </view>
      <picker 
        mode="selector" 
        range="{{aiProviderOptions}}" 
        bindchange="onAiProviderChange"
        value="{{aiProviderIndex}}">
        <view class="picker-value">
          {{aiProviderOptions[aiProviderIndex]}}
        </view>
      </picker>
    </view>
    <view class="setting-item column">
      <view class="setting-info">
        <text class="setting-label">API Key</text>
        <text class="setting-desc">输入你的 AI API Key</text>
      </view>
      <input 
        class="api-input" 
        placeholder="请输入 API Key"
        value="{{aiApiKey}}"
        bindinput="onAiApiKeyInput"
        password="true"
      />
    </view>
    <view class="bind-tip">
      <text wx:if="{{aiApiKey}}">✅ API Key 已配置</text>
      <text wx:else>未配置 API Key，将使用基础 OCR 识别</text>
    </view>
  </view>

  <!-- 服务号推送设置 -->
  <view class="section">
    <view class="section-title">服务号推送设置</view>
    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-label">开启尾款提醒</text>
        <text class="setting-desc">在尾款到期前收到服务号推送提醒</text>
      </view>
      <switch 
        checked="{{enableReminder}}" 
        bindchange="toggleReminder"
        color="#07C160"
      />
    </view>
    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-label">提醒时间</text>
        <text class="setting-desc">提前几天提醒</text>
      </view>
      <picker 
        mode="selector" 
        range="{{remindDaysOptions}}" 
        bindchange="onRemindDaysChange"
        value="{{remindDaysIndex}}">
        <view class="picker-value">
          提前{{remindDaysOptions[remindDaysIndex]}}天
        </view>
      </picker>
    </view>
  </view>

  <view class="section">
    <view class="section-title">绑定服务号</view>
    <view class="bind-tip">
      <text wx:if="{{!hasBind}}">
        点击下方按钮绑定服务号，绑定后才能接收推送提醒
      </text>
      <text wx:else class="bind-success">
        ✅ 已成功绑定服务号
      </text>
    </view>
    <button 
      wx:if="{{!hasBind}}" 
      class="btn bind-btn" 
      bindtap="bindServiceAccount">
      绑定服务号
    </button>
  </view>

  <view class="section">
    <view class="section-title">测试推送</view>
    <button 
      class="btn test-btn" 
      bindtap="testPush"
      disabled="{{!enableReminder}}">
      发送测试消息
    </button>
  </view>
</view>
