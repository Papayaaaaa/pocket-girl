/* settings.wxss */
.container {
  padding: 32rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.picker-value {
  font-size: 28rpx;
  color: #07C160;
}

.bind-tip {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.bind-success {
  color: #07C160;
}

.btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}

.bind-btn {
  background: #07C160;
  color: #fff;
}

.test-btn {
  background: #F5F5F7;
  color: #333;
}

.test-btn[disabled] {
  color: #999;
}
