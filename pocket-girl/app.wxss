/** app.wxss - Apple Style Global **/
page {
  background-color: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #3C3C43;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 16rpx;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn {
  background: #007AFF;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn:active {
  opacity: 0.7;
}

.btn-secondary {
  background: #F2F2F7;
  color: #007AFF;
}

/* 输入框 */
.input {
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.input-placeholder {
  color: #8E8E93;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-guzi { background: #FF6B9D20; color: #FF6B9D; }
.tag-hanfu { background: #34C75920; color: #34C759; }
.tag-lo { background: #FF950020; color: #FF9500; }
.tag-other { background: #8E8E9320; color: #8E8E93; }

/* 金额 */
.amount {
  font-size: 36rpx;
  font-weight: 600;
}

.amount-paid { color: #34C759; }
.amount-pending { color: #FF3B30; }

/* 通用文字颜色 */
.text-primary { color: #007AFF; }
.text-success { color: #34C759; }
.text-warning { color: #FF9500; }
.text-danger { color: #FF3B30; }
.text-muted { color: #8E8E93; }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #E5E5EA;
  margin: 20rpx 0;
}
