<!--detail.wxml-->
<view class="container">
  <!-- 逾期提示 -->
  <view class="overdue-banner" wx:if="{{record.isOverdue}}">
    <text class="overdue-icon">⚠️</text>
    <text>该订单已逾期 {{-record.daysLeft}} 天，请尽快支付尾款！</text>
  </view>

  <view class="card">
    <view class="detail-header">
      <view class="detail-title">{{record.name}}</view>
      <view class="tag tag-{{record.category}}">{{record.categoryText}}</view>
    </view>
    
    <view class="detail-shop" wx:if="{{record.shop}}">🏪 {{record.shop}}</view>
    
    <view class="detail-amounts">
      <view class="amount-row">
        <text class="amount-label">定金</text>
        <text class="amount amount-paid">¥{{record.deposit}}</text>
      </view>
      <view class="amount-row">
        <text class="amount-label">尾款</text>
        <text class="amount {{record.isPaid ? 'amount-paid' : 'amount-pending'}}">¥{{record.tailPrice}}</text>
      </view>
      <view class="amount-row total">
        <text class="amount-label">总价</text>
        <text class="amount">¥{{record.totalPrice}}</text>
      </view>
    </view>
    
    <view class="detail-deadline">
      <text class="deadline-label">尾款截止</text>
      <view class="deadline-right">
        <text class="deadline-date {{record.daysLeft <= 3 && !record.isPaid ? 'urgent' : ''}} {{record.isOverdue ? 'overdue' : ''}}">{{record.tailDeadline}}</text>
        <text class="deadline-tip" wx:if="{{!record.isPaid}}">
          <text wx:if="{{record.isOverdue}}" class="overdue-text">已逾期 {{-record.daysLeft}} 天</text>
          <text wx:elif="{{record.daysLeft > 0}}">还有 {{record.daysLeft}} 天</text>
          <text wx:else>今天到期</text>
        </text>
        <text class="deadline-tip" wx:else>已支付 {{record.paidAtText}}</text>
      </view>
    </view>
    
    <view class="detail-remark" wx:if="{{record.remark}}">
      <text class="remark-label">备注</text>
      <text class="remark-content">{{record.remark}}</text>
    </view>

    <view class="detail-images" wx:if="{{record.images && record.images.length > 0}}">
      <text class="remark-label">图片 ({{record.images.length}})</text>
      <scroll-view class="images-scroll" scroll-x="true">
        <block wx:for="{{record.images}}" wx:key="*this">
          <image 
            src="{{item}}" 
            mode="aspectFill" 
            class="detail-image"
            bindtap="previewImage"
            data-index="{{index}}"
          />
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 快捷支付按钮 -->
  <view class="quick-pay-section" wx:if="{{!record.isPaid}}">
    <view class="quick-pay-btn" bindtap="quickPay">
      <text class="pay-icon">💳</text>
      <text>立即支付尾款 ¥{{record.tailPrice}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-btns">
    <view class="btn btn-secondary" bindtap="togglePaid">
      {{record.isPaid ? '撤销支付' : '标记已支付'}}
    </view>
    <view class="btn btn-edit" bindtap="editRecord">编辑</view>
  </view>
  
  <view class="btn btn-danger" bindtap="deleteRecord">删除记录</view>
  
  <!-- 分享 -->
  <view class="share-section">
    <button class="share-btn" open-type="share">分享给朋友</button>
  </view>
</view>
