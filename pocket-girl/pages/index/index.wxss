/* index.wxss */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.settings-icon {
  font-size: 40rpx;
  padding: 8rpx;
}

.filter-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

.record-list {
  padding-bottom: 120rpx;
}

.record-card {
  transition: transform 0.2s;
}

.record-card:active {
  transform: scale(0.98);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.record-shop {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.record-amounts {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.amount-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.amount-item .amount {
  font-size: 28rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.deadline {
  font-size: 24rpx;
  color: #666;
}

.deadline.urgent {
  color: #FF6B6B;
  font-weight: 500;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-badge.paid {
  background: #E8F7E9;
  color: #07C160;
}

.status-badge.pending {
  background: #FFF0F0;
  color: #FF6B6B;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  text-align: center;
  color: #999;
  line-height: 1.6;
}

.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}
