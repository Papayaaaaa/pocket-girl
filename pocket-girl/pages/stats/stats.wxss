/* stats.wxss - Apple Style */

/* 周期切换 tabs */
.period-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8E8E93;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #007AFF;
  color: #FFFFFF;
  font-weight: 500;
}

/* 总览卡片 */
.stats-overview {
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.3);
}

.overview-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 24rpx;
  font-weight: 500;
}

.overview-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}

.overview-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -1rpx;
}

.overview-amount.pending {
  color: #FFE066;
}

.overview-amount.paid {
  color: #A8E6CF;
}

.overview-count {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.overview-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.total-amount {
  font-size: 38rpx;
  font-weight: 700;
}

/* 通用区块 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.1);
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #3C3C43;
}

/* 分类统计 */
.category-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-bar-item {
  display: flex;
  flex-direction: column;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #3C3C43;
  margin-bottom: 8rpx;
}

.bar-label text:last-child {
  font-weight: 600;
}

.count-badge {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 400;
  margin-left: 8rpx;
}

.bar-track {
  height: 16rpx;
  background: #F2F2F7;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.empty-category {
  text-align: center;
  padding: 40rpx;
  color: #8E8E93;
  font-size: 26rpx;
}

/* 近期到期 */
.upcoming-list {
  display: flex;
  flex-direction: column;
}

.upcoming-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E5E5EA;
}

.upcoming-item:last-child {
  border-bottom: none;
}

.upcoming-info {
  display: flex;
  flex-direction: column;
}

.upcoming-name {
  font-size: 28rpx;
  color: #3C3C43;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.upcoming-date {
  font-size: 22rpx;
  color: #8E8E93;
  background: #F2F2F7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.upcoming-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF3B30;
}
