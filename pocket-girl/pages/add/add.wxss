/* add.wxss */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: #F5F5F7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.category-item.active {
  background: #E8F7E9;
  border-color: #07C160;
  color: #07C160;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.amount-inputs {
  display: flex;
  gap: 16rpx;
}

.amount-input-item {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.amount-input-item .amount-label {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.amount-input-item .input {
  background: transparent;
  padding: 20rpx 12rpx;
}

.total-preview {
  text-align: right;
  font-size: 26rpx;
  color: #07C160;
  margin-top: 12rpx;
  font-weight: 500;
}

.picker-trigger {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.arrow {
  font-size: 36rpx;
  color: #999;
}

.textarea {
  width: 100%;
  background: #F5F5F7;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}

.save-btn {
  margin-top: 48rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-add {
  aspect-ratio: 1;
  background: #F5F5F7;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
